{
  "name": "vite-plugin-qrcode",
  "description": "Show QR code on server start",
  "version": "0.3.0",
  "license": "MIT",
  "author": "bluwy",
  "type": "module",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "types"
  ],
  "scripts": {
    "check:publint": "publint --strict",
    "check:types": "tsc --noEmit",
    "generate:types": "dts-buddy -m \"vite-plugin-qrcode:src/public.d.ts\"",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svitejs/vite-plugin-qrcode.git",
    "directory": "packages/vite-plugin-qrcode"
  },
  "keywords": [
    "vite-plugin",
    "vite plugin",
    "vite",
    "qrcode"
  ],
  "bugs": {
    "url": "https://github.com/svitejs/vite-plugin-qrcode/issues"
  },
  "homepage": "https://github.com/svitejs/vite-plugin-qrcode#readme",
  "dependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "peerDependencies": {
    "vite": ">=3"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "tsdown": "^0.21.4",
    "vite": "^8.0.0",
    "vitest": "^4.1.1"
  }
}
