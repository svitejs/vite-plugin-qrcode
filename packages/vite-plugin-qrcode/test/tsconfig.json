{
	"include": ["**/*.spec.ts"],
	"compilerOptions": {
		"noEmit": true,
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"noUnusedLocals": true,
		"baseUrl": ".",
		"resolveJsonModule": true,
		"allowJs": true,
		"checkJs": true,
		"allowSyntheticDefaultImports": true
	}
}
